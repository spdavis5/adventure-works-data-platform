# !! IMPORTANT: Don't put your credentials in this file. Instead, make two copies
#               (one called .env.dev and the other .env.docker) where you can put
#               your credentials. (Those file names will be ignored by git.)

# ============================================================================
# Data Sources and ETL
# ============================================================================

# MongoDB
MONGO_HOST=mongo
# MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=support_logs
MONGO_COLLECTION=chats

# PostgreSQL
POSTGRES_HOST=postgres
# POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=transactions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Snowflake
SNOWFLAKE_USER=username                      # <-- update these
SNOWFLAKE_PASSWORD=password                  # <-- update these
SNOWFLAKE_ACCOUNT=snowflake-account          # <-- update these
SNOWFLAKE_WAREHOUSE=your_wh                  # <-- update these
SNOWFLAKE_DATABASE=ADVENTURE_WORKS                   # <-- update these
SNOWFLAKE_ROLE=ACCOUNTADMIN                  # <-- REQUIRED: set to your Snowflake role

SNOWFLAKE_SCHEMA=RAW_EXT                     # <-- leave these alone
ORDERS_STAGE=orders_stage                    # <-- leave these alone
ORDER_DETAILS_STAGE=order_details_stage      # <-- leave these alone
CHAT_STAGE=chat_stage                        # <-- leave these alone

# Processor run mode: 0 = run once and exit, 300 = repeat every 5 minutes
PROCESSOR_INTERVAL_SEC=0                     # <-- use 0 during development, 300 for continuous

# Enable/disable COPY INTO and cleanup (for testing/debugging)
PROCESSOR_ENABLE_COPY_INTO=true
PROCESSOR_ENABLE_CLEANUP=true

# Auto-shutdown (0 = run forever)
PROCESSOR_MAX_RUNTIME_SEC=3600               # <-- auto-shutdown after 1 hour

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# Web Analytics / Orchestration 
# ============================================================================

# Web Analytics API Endpoint
API_BASE_URL=https://platform-api.fly.dev

# Prefect API URL 
# Use http://localhost:4200/api for local 'uv run' execution
# Use http://prefect-server:4200/api for Docker Compose execution
PREFECT_API_URL=http://localhost:4200/api

# Flow schedule (minutes between automated runs)
FLOW_SCHEDULE_MINUTES=15